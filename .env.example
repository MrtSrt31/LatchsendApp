# Example environment variables for Latchsend
# Copy this file to .env and fill in the values as needed

# SQLite database file
DATABASE_URL="file:./dev.db"

# WebSocket signaling server port
SIGNAL_PORT=8080

# Node.js server port
PORT=3000

# Prisma log level (optional)
# PRISMA_LOG_LEVEL=info

# Add other secrets or configuration as needed
